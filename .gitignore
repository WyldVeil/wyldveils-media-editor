soundfonts/*.sf2
soundfonts/*.sf3

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Editor artefacts
.vscode/
.idea/
*.swp
*.swo

# Temporary / build
*.log
*.tmp
dist/
build/
*.spec
